<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sum Sum Elite - Artiste Musical</title>
    <link rel="stylesheet" href="styles.css">

    <!-- 🔷 STYLE DU LOADING -->
    <style>
        #loading-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100vh;
            background: linear-gradient(135deg, #0a0a0f 0%, #1a1a2e 50%, #0a0a0f 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            transition: opacity 1s ease-out;
        }

        #loading-screen.fade-out {
            opacity: 0;
            pointer-events: none;
        }

        .loading-content {
            text-align: center;
        }

        .connecting-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 2rem;
        }

        .connecting-container.hidden {
            display: none;
        }

        .spinner-ring {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            position: relative;
            animation: rotate 2s linear infinite;
        }

        .spinner-ring::before {
            content: '';
            position: absolute;
            width: 100%;
            height: 100%;
            border-radius: 50%;
            border: 4px solid transparent;
            border-top: 4px solid #8b5cf6;
        }

        .spinner-ring-inner {
            position: absolute;
            top: 20px;
            left: 20px;
            right: 20px;
            bottom: 20px;
            border-radius: 50%;
            border: 2px dashed rgba(139,92,246,0.4);
        }

        .loading-text {
            color: white;
            font-size: 1.5rem;
            text-transform: uppercase;
        }

        .dots-container {
            display: flex;
            gap: 0.5rem;
        }

        .dot {
            width: 10px;
            height: 10px;
            background: #8b5cf6;
            border-radius: 50%;
            animation: bounce 1.4s infinite;
        }

        .dot:nth-child(2) { animation-delay: 0.2s; }
        .dot:nth-child(3) { animation-delay: 0.4s; }

        .success-container {
            display: none;
            flex-direction: column;
            align-items: center;
        }

        .success-container.visible {
            display: flex;
        }

        .success-icon {
            width: 100px;
            height: 100px;
            background: #10b981;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .bon-voyage-text {
            margin-top: 20px;
            font-size: 2rem;
            color: #10b981;
            font-weight: bold;
        }

        @keyframes rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        @keyframes bounce {
            0%,80%,100% { transform: scale(0.6); }
            40% { transform: scale(1); }
        }
    </style>
</head>

<body>

    <!-- 🔷 LOADER -->
    <div id="loading-screen">
        <div class="loading-content">
            <div class="connecting-container" id="connecting-phase">
                <div class="spinner-ring">
                    <div class="spinner-ring-inner"></div>
                </div>
                <h1 class="loading-text">Connexion Au Site Web</h1>
                <div class="dots-container">
                    <span class="dot"></span>
                    <span class="dot"></span>
                    <span class="dot"></span>
                </div>
            </div>

            <div class="success-container" id="success-phase">
                <div class="success-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
                        <path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <h1 class="bon-voyage-text">BON VOYAGE</h1>
            </div>
        </div>
    </div>

    <!-- ✅ TON SITE EXISTANT (INCHANGÉ) -->

    <!-- Header -->
    <header class="header">
        <div class="container">
            <div class="header-content">
                <a href="index.html" class="logo">
                    <img src="assets/Logo.jpeg" alt="Sum Sum Elite Logo">
                    <span>Sum Sum Elite</span>
                </a>
                <nav class="nav desktop-nav">
                    <a href="index.html" class="nav-link active">Accueil</a>
                    <a href="music.html" class="nav-link">Musique</a>
                    <a href="about.html" class="nav-link">À Propos</a>
                    <a href="projects.html" class="nav-link">Projets</a>
                    <a href="gallery.html" class="nav-link">Galerie</a>
                    <a href="contact.html" class="nav-link">Contact</a>
                </nav>
            </div>
        </div>
    </header>

    <!-- Hero -->
    <section class="hero">
        <div class="hero-content">
            <img src="assets/Logo.jpeg" class="hero-logo">
            <h1 class="hero-title">Sum Sum Elite</h1>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <p>&copy; 2024 Sum Sum Elite</p>
    </footer>

    <!-- 🔷 SCRIPT LOADER -->
    <script>
        const loadingScreen = document.getElementById('loading-screen');
        const connectingPhase = document.getElementById('connecting-phase');
        const successPhase = document.getElementById('success-phase');

        setTimeout(() => {
            connectingPhase.classList.add('hidden');
            successPhase.classList.add('visible');
        }, 3000);

        setTimeout(() => {
            loadingScreen.classList.add('fade-out');
        }, 4500);

        setTimeout(() => {
            loadingScreen.style.display = "none";
        }, 5500);
    </script>

    <script src="script.js"></script>
</body>
</html>
